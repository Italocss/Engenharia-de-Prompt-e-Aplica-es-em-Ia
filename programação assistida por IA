      "source": [
        "def get_numbers():\n",
        "    \"\"\"Gets two numbers from the user.\"\"\"\n",
        "    while True:\n",
        "        try:\n",
        "            num1 = float(input(\"Digite o primeiro número: \"))\n",
        "            num2 = float(input(\"Digite o segundo número: \"))\n",
        "            return num1, num2\n",
        "        except ValueError:\n",
        "            print(\"Entrada inválida. Por favor, digite números válidos.\")\n",
        "\n",
        "def add(x, y): return x + y\n",
        "def subtract(x, y): return x - y\n",
        "def multiply(x, y): return x * y\n",
        "def divide(x, y):\n",
        "    if y != 0:\n",
        "        return x / y\n",
        "    else:\n",
        "        return \"Erro: divisão por zero não é permitida.\"\n",
        "\n",
        "def calculadora_refatorada():\n",
        "    \"\"\"Refactored calculator function.\"\"\"\n",
        "    operations = {\n",
        "        '1': (\"Soma\", add),\n",
        "        '2': (\"Subtração\", subtract),\n",
        "        '3': (\"Multiplicação\", multiply),\n",
        "        '4': (\"Divisão\", divide)\n",
        "    }\n",
        "\n",
        "    print(\"Selecione a operação:\")\n",
        "    for key, (name, _) in operations.items():\n",
        "        print(f\"{key} - {name}\")\n",
        "\n",
        "    while True:\n",
        "        escolha = input(\"Digite o número da operação desejada (1/2/3/4): \")\n",
        "        if escolha in operations:\n",
        "            break\n",
        "        else:\n",
        "            print(\"Opção inválida. Por favor, escolha uma das opções (1/2/3/4).\")\n",
        "\n",
        "    num1, num2 = get_numbers()\n",
        "\n",
        "    operation_name, operation_func = operations[escolha]\n",
        "    result = operation_func(num1, num2)\n",
        "\n",
        "    if isinstance(result, str): # Handle division by zero error message\n",
        "        print(result)\n",
        "    else:\n",
        "        print(f\"{num1} {operation_name.lower()} {num2} = {result}\")\n",
        "\n",
        "# Executa a calculadora refatorada\n",
        "calculadora_refatorada()\n"
      ],
